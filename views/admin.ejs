<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/styles.css">
    <title>DEI CMT | Admin's Dashboard</title>
</head>
<body>
    <%- include('partials/header copy') %>

    <div class="container">


        <div class="accordion" id="accordionExample">
  <div class="accordion-item">
    <h2 class="accordion-header">
      <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseOne" aria-expanded="false" aria-controls="collapseOne">
        <strong>Manage Chairs</strong>
      </button>
    </h2>
    <div id="collapseOne" class="accordion-collapse collapse" data-bs-parent="#accordionExample">
      <div class="accordion-body">

        <h5>Create New Chair Credentials</h5><hr>

          <form action="/create-chair-credentials" method="post">

        <input class="form-control" type="text" name="name" placeholder="Name"><br>
        <input class="form-control" type="email" name="email" placeholder="Email ID"><br>
        <input class="form-control" type="text" name="contact_number" placeholder="Contact Number"><br>
        <input class="form-control" type="text" name="faculty" placeholder="Faculty"><br>
        <input class="form-control" type="text" name="department" placeholder="Department"><br>
        <input class="btn btn-primary" type="submit" value="Create Chair Credentials"><br>
        <p class="small">(An auto-generated password will be sent to the user)</p>

        

    </form><hr>

    <h5>Existing Chairs</h5><hr>

    <% if(chairs && chairs.length>0) { %>

        <table class="table">
        <tr>
            <th>
                Name
            </th>
            <th>Email ID</th>
            <th>Contact Number</th>
            <th>Faculty</th>
            <th>Department</th>
            <th>Action</th>
        </tr>
        <% chairs.forEach(function(chairs){ %>

<tr>
    <td>
        <%= chairs.name %>
    </td>
    <td>
        <%= chairs.email %>
    </td>
    <td>
        <%= chairs.contact_number %>
    </td>
    <td>
        <%= chairs.faculty %>
    </td>
    <td>
        <%= chairs.department %>
    </td>
    <td>
        <a href="/delete-account/<%=chairs.email%>"  class="btn btn-danger">Delete Account</a><% if(chairs.status=="ACCESS REVOKED"){ %>
          <a href="/grant-access/<%=chairs.email%>" class="btn btn-success">Re-Grant Access</a> <% } else { %>
          <a href="/revoke-access/<%=chairs.email%>" class="btn btn-warning">Revoke Access</a>
          <a href="/reset-chair-password/<%=chairs.email%>" class="btn btn-secondary">Reset Password</a>
          <% } %>
    </td>

</tr>
        
        
        <% }) %>

            </table>

    
    <% } else { %>

        <p class="small">No Chairs Found!</p>

        <% } %>



      </div>
    </div>
  </div>
  <div class="accordion-item">
    <h2 class="accordion-header">
      <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseTwo" aria-expanded="false" aria-controls="collapseTwo">
        <strong>Manage Conferences</strong>
      </button>
    </h2>
    <div id="collapseTwo" class="accordion-collapse collapse" data-bs-parent="#accordionExample">
      <div class="accordion-body">

        <% if(conferences && conferences.length>0) { %>

            <table class="table">
                <tr>
                    <th>Title</th>
                    <th>Created By</th>
                    <th>Action</th>
                </tr>

            <% conferences.forEach(function(conferences){ %>
            
            <tr>
                <td><%= conferences.title%></td>
                <td><%= conferences.created_by %></td>
                <td><a href="" class="btn btn-danger">Terminate Conference</a></td>
            </tr>
            
            <% }) %>
            </table>
        <% } else { %>

            <p class="small">No Conferences Found!</p>


            <% } %>



      </div>
    </div>
  </div>

<hr>

 

  

