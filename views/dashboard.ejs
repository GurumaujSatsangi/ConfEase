<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>DEI CMT</title>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link rel="shortcut icon" href="/dei_logo.png" type="image/x-icon">
    <link rel="stylesheet" href="/styles.css">
  </head>
  <body>
    <%
    // Helper function to format yyyy-mm-dd to dd-mm-yyyy for display
    function formatDateDisplay(dateStr) {
      if (!dateStr) return dateStr;
      const parts = dateStr.split('-');
      if (parts.length === 3) {
        return `${parts[2]}-${parts[1]}-${parts[0]}`;
      }
      return dateStr;
    }
    %>
    <%- include('partials/dashboard/header') %>
    <div class="container">

      <h4>Welcome <%= user.name %> (<%=user.email %>)!</h4><hr>

        <h4>Active Conferences</h4>
        <% if (conferences && conferences.length > 0) { %> 
          <% conferences.forEach(function(conference) { 
              // 1. Create conference-specific role checks to prevent buttons bleeding into the wrong accordion
              const isConfReviewer = typeof conference_ids_for_reviewer !== 'undefined' && conference_ids_for_reviewer.includes(conference.conference_id);
              const isConfSessionChair = typeof conference_ids_for_session_chair !== 'undefined' && conference_ids_for_session_chair.includes(conference.conference_id);
              const isConfInvitee = typeof conference_ids_for_invited_talk !== 'undefined' && conference_ids_for_invited_talk.includes(conference.conference_id);
              const isConfPosterCoord = typeof conference_ids_for_poster_presentation_coordinator !== 'undefined' && conference_ids_for_poster_presentation_coordinator.includes(conference.conference_id);
              
              // 2. Global check using array lengths: Reviewers/Chairs/Invitees cannot submit papers to ANY conference
              const isAnyReviewer = typeof conference_ids_for_reviewer !== 'undefined' && conference_ids_for_reviewer.length > 0;
              const isAnySessionChair = typeof conference_ids_for_session_chair !== 'undefined' && conference_ids_for_session_chair.length > 0;
              const isAnyInvitee = typeof conference_ids_for_invited_talk !== 'undefined' && conference_ids_for_invited_talk.length > 0;

              const blockSubmissions = isAnyReviewer || isAnySessionChair || isAnyInvitee;
          %>

          <div class="accordion" id="accordion-<%= conference.conference_id %>">
            <div class="accordion-item">
              <h2 class="accordion-header" id="heading-<%= conference.conference_id %>">
                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapse-<%= conference.conference_id %>" aria-expanded="false" aria-controls="collapse-<%= conference.conference_id %>">
                  <b><%= conference.title %> </b>&nbsp;-&nbsp;<span class="badge rounded-pill bg-info text-dark"><%= conference.conference_id %></span>
                </button>
              </h2>
              <div id="collapse-<%= conference.conference_id %>" class="accordion-collapse collapse" aria-labelledby="heading-<%= conference.conference_id %>" data-bs-parent="#accordion-<%= conference.conference_id %>">
                <div class="accordion-body">
                  <div class="card mb-3">
                    <div class="card-body">
                      <table class="table table-bordered" border="1" style="width: 100%">
                        <tr>
                            <td colspan="3">
                        <div class="accordion" id="accordionExample">

<div class="accordion-item">
    <h2 class="accordion-header">
      <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseOnee" aria-expanded="false" aria-controls="collapseOnee">
        <Strong>Conference Description</Strong>
      </button>
    </h2>
    <div id="collapseOnee" class="accordion-collapse collapse" data-bs-parent="#accordionExample">
      <div class="accordion-body">
        <%= conference.description %>
      </div>
    </div>
  </div>  </div>                      </td>

                        </tr>

                        <tr>
                          <td>Conference Timeline</td>
                          <td>Start Date: <br><b><%= formatDateDisplay(conference.conference_start_date) %></b></td>
                          <td>End Date: <br><b><%= formatDateDisplay(conference.conference_end_date) %></b></td>
                        </tr>
                        <tr>
                          <td>Full Paper Submission: <br><b><%= formatDateDisplay(conference.full_paper_submission) %> (11:59 PM IST)</b></td>
                          <td>Acceptance Notification: <br><b><%= formatDateDisplay(conference.acceptance_notification) %> (11:59 PM IST)</b></td>
                          <td>Final Camera Ready Paper Submission: <br><b><%= formatDateDisplay(conference.camera_ready_paper_submission) %> (11:59 PM IST)</b></td>
                        </tr>
       <tr>

        
  <td colspan="3">

    <div class="accordion" id="accordionFlushExample">
  <div class="accordion-item">
    <h2 class="accordion-header">
      <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#flush-collapseOne" aria-expanded="false" aria-controls="flush-collapseOne">
        <strong>Official Email ID for Communication / List of Conference Chairs</strong>
      </button>
    </h2>
    
    <div id="flush-collapseOne" class="accordion-collapse collapse" data-bs-parent="#accordionFlushExample">
      <div class="accordion-body">

 <strong>Any Conference related query should be sent to: <a href="mailto:<%= conference.communication %>"><%= conference.communication %></a></strong>
    <hr>
    <h6>Conference Chairs:</h6>

    <% 
      // 1. Safely handle the data whether it's a String or an Array
      let chairsList = [];
      if (Array.isArray(conference.co_chairs)) {
        chairsList = conference.co_chairs;
      } else if (typeof conference.co_chairs === 'string') {
        // Remove postgres curly braces {} if they exist, then split by comma
        chairsList = conference.co_chairs.replace(/^{|}$/g, '').split(',');
      }
    %>

    <% if (chairsList && chairsList.length > 0) { %>
      <ul>
        <% chairsList.forEach(function(chair) { %>
          <li><%= chair.replace(/"/g, '').trim() %></li>
        <% }); %>
      </ul>
    <% } else { %>
      <p class="small">No Conference Chairs Listed!</p>
    <% } %>

      </div>
    </div>
  </div>
  

</div>



   
  </td>
</tr>
                        <tr>
                          <td></td>
                          <% if (currentDate > conference.full_paper_submission) { %>
                            <td colspan="2"><span class="badge-rejected"><b>Due Date to submit or join a paper is over</b></span></td>
                          <% } else { %>              
                            <td>  
                              <% if(blockSubmissions) { %>
                                <a href="/dashboard?message=Please note, Reviewers / Session Chairs / Invited Speakers are not allowed to submit papers. If you think this is an error, please reach out to us at multimedia@dei.ac.in."
                                   class="btn btn-outline-primary" style="width: 350px" role="button" aria-disabled="true">
                                   Submit a Paper as Primary Author<br>(Not Allowed)
                                </a>
                              <% } else { %>     
                                <a href="/submission/primary-author/<%= conference.conference_id %>"
                                   class="btn btn-outline-primary" style="width: 350px" role="button">
                                   Submit a Paper as Primary Author
                                </a>  
                              <% } %>
                            </td>

                            <td>  
                              <% if(blockSubmissions) { %>
                                <a href="/dashboard?message=Please note, Reviewers / Session Chairs / Invited Speakers are not allowed to join papers as co-authors. If you think this is an error, please reach out to us at multimedia@dei.ac.in."
                                   class="btn btn-outline-primary" style="width: 350px" role="button" aria-disabled="true">
                                   Join a Paper as Co-Author<br>(Not Allowed)
                                </a>
                              <% } else { %>     
                                <a href="/submission/co-author/<%= conference.conference_id %>"
                                   class="btn btn-outline-primary" style="width: 350px" role="button">
                                   Join a Paper as Co-Author
                                </a>  
                              <% } %>
                            </td>
                          <% } %>
                        </tr>
                        
                        <tr>
                          <td colspan="4">
                            <% if(isConfReviewer) { %>
                                <center>
                                  <a href="/reviewer/<%=conference.conference_id%>" style="width:300px; margin-bottom: 5px;" class="btn btn-outline-success">Review Papers</a>
                                </center>
                            <% } %>
                            
                            <% if(isConfInvitee) { %>
                                <center>
                                  <a href="/submission/invited-talk/<%= conference.conference_id %>" style="width:300px; margin-bottom: 5px;" class="btn btn-outline-success">Submit Paper for Invited Talk</a>
                                </center>
                            <% } %>

                            <% if(isConfSessionChair) { %>
                                <center>
                                  <a href="/panelist/active-session/<%= conference.conference_id %>" style="width:300px; margin-bottom: 5px;" class="btn btn-outline-success">Start Oral Presentation</a>
                                </center>
                            <% } %>

                            <% if(isConfPosterCoord) { %>
                                <center>
                                  <a href="/score-posters/<%= conference.conference_id %>" style="width:300px; margin-bottom: 5px;" class="btn btn-outline-success">Score Posters</a>
                                </center>
                            <% } %>
                          </td>
                        </tr>
                      </table>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        <% }); %> 
      <% } else { %>
        <h6><i class="bi bi-emoji-frown-fill"></i> &nbsp;There are No Active Conferences at the moment.</h6>
      <% } %>

      <hr />

      <% if(typeof invitedTalkSubmissions !== 'undefined' && invitedTalkSubmissions && invitedTalkSubmissions.length > 0){ %>
        <h4>Invited Talk Submissions</h4>
        <ul>
          <% invitedTalkSubmissions.forEach(function(talk) { %>
            <li>
              <a href="<%=talk.file_url%>" style="text-decoration: none;" target="_blank"> <%= talk.title %> <i class="bi bi-box-arrow-up-right"></i></a>&nbsp;|&nbsp;<span class="badge rounded-pill bg-info text-dark">Conference ID: <%= talk.conference_id %></span>

              (<a style="text-decoration: none;color:red" href="/submission/delete/invitee/<%= talk.paper_id%>"><i class="bi bi-trash3-fill"></i></a>)
            </li>
          <% }); %>
        </ul>
      <% } %>

     <h4>My Submissions</h4>
      <% if (userSubmissions && userSubmissions.length > 0) { %> 
        <% userSubmissions.forEach(function(submission) { %>

        <div class="accordion mb-3" id="accordion-sub-<%= submission.submission_id %>">
          <div class="accordion-item">
            <h2 class="accordion-header" id="heading-sub-<%= submission.submission_id %>">
              <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapse-sub-<%= submission.submission_id %>" aria-expanded="false" aria-controls="collapse-sub-<%= submission.submission_id %>">
                  <strong><%= submission.title %></strong>&nbsp;-&nbsp;<span class="badge rounded-pill bg-warning text-dark"><%= submission.submission_status %></span>&nbsp;-&nbsp;<span class="badge rounded-pill bg-info text-dark"><%= submission.conference_id %></span>

              </button>
            </h2>
            <div id="collapse-sub-<%= submission.submission_id %>" class="accordion-collapse collapse" aria-labelledby="heading-sub-<%= submission.submission_id %>" data-bs-parent="#accordion-sub-<%= submission.submission_id %>">
              <div class="accordion-body p-0"> <div class="card border-0"> <div class="card-body">
                    <div class="table-responsive">
                      <table class="table table-bordered table-sm">
                      <tr>
                        <th style="max-width: 200px;">Abstract</th>
                        <th style="min-width: 120px;">Track</th>
                        <th style="width: 80px; text-align: center;">View Paper</th>
                        <% if (submission.primary_author === user.email) { %>
                          <th style="max-width: 150px;">Co-Authors </th>
                        <% } else if (Array.isArray(submission.co_authors) && submission.co_authors.includes(user.email)) { %>
                          <th style="max-width: 150px;">Primary Author</th>
                        <% } %>
                        <th style="min-width: 120px;">Paper Code</th>
                        <th style="min-width: 120px;">AI Generated Content Detection Score & Verdict</th>
                        <th style="min-width: 120px;">Status</th>
                        <th style="max-width: 200px;">Final Camera Ready Paper Submission</th>
                        <th style="max-width: 150px;">Presentation Date & Time</th>
                        <th style="width: 100px; text-align: center;">Action</th>
                      </tr>
                      <tr>
                        <td style="max-width: 200px; word-wrap: break-word; overflow-wrap: break-word;">
                          <div style="max-height: 60px; overflow-y: auto;">
                            <%= submission.abstract %>
                          </div>
                        </td>
                        <td><%= submission.track_name %></td>
                        <td style="text-align: center;">
                          <a href="<%= submission.file_url %>" target="_blank" class="btn btn-sm btn-outline-info">
                            <i class="bi bi-eye-fill"></i>
                          </a>
                        </td>
                        
                        <% if (submission.primary_author === user.email) { %>
                          <td style="max-width: 150px; word-wrap: break-word;">
                            <% if(!submission.co_authors){ %>
                              <p class="small">No Co-Authors at the moment. Click on <i class="bi bi-bell-fill"></i> in the action column to manage requests. </p> 
                            <% } else { %>
                              <%= submission.co_authors %> 
                            <% } %>
                          </td>
                        <% } else if (Array.isArray(submission.co_authors) && submission.co_authors.includes(user.email)) { %>
                          <td style="max-width: 150px; word-wrap: break-word;">
                            <small><%= submission.primary_author_formatted %></small>
                          </td>
                        <% } %>

                        <td><%= submission.paper_code %></td>
                        <td>Score: <%= submission.ai_score %> | Verdict: <%= submission.is_ai %>
                          <% if (submission.is_ai === "true") { %>
                            <p class="small">(<b>Your submission has been marked as AI generated.</b> However, it will still be reviewed by the reviewers. Please note, the score and verdict are visible to the reviewers and may impact the acceptance decision. If you think this is an error, please reach out to the conference chairs.)</p>
                          <% } else { %>
                            <p class="small">(<b>Your submission has NOT been marked as AI generated.</b> Please note, the score and verdict are visible to the reviewers and may impact the acceptance decision.)</p>
                          <% } %> 
                        </td>

                        <td><%= submission.submission_status %></td>
                        
                        <td>
                          <% if (submission.submission_status == "Accepted for Poster Presentation" || submission.submission_status == "Accepted for Oral Presentation") { %>
                            <% if (submission.primary_author === user.email) { %>
                              <span class="badge-reviewed"><i class="bi bi-check-circle-fill"></i> <br>This submission has been Accepted. Please click on the link given below to submit the Final Camera Ready Paper.</span><br>
                              <a class="btn btn-sm btn-primary mt-2" href="/submission/final-camera-ready/primary-author/<%= submission.submission_id %>">Submit</a>
                            <% } else if (Array.isArray(submission.co_authors) && submission.co_authors.includes(user.email)) { %>
                              <span class="badge-reviewed"><i class="bi bi-check-circle-fill"></i> <br>This submission has been Accepted. Please ask the Primary Author to submit the Final Camera Ready Paper.</span>
                            <% } %>
                          <% } else if (submission.submission_status == "Submitted for Review" ) { %>
                            <span class="badge-review">Awaiting Decision</span>
                          <% } else if (submission.submission_status == "Submitted Final Camera Ready Paper for Oral Presentation" ) { %>
                            <span class="badge-submitted">✓ Final camera ready paper submitted (Oral Presentation)</span>
                          <% } else if (submission.submission_status == "Submitted Final Camera Ready Paper for Poster Presentation" ) { %>
                            <span class="badge-submitted">✓ Final camera ready paper submitted (Poster Presentation)</span>
                          <% } else if (submission.submission_status == "Submitted Final Camera Ready Paper" ) { %>
                            <% if (submission.primary_author === user.email) { %>
                              <span class="badge-submitted">✓ Final Camera Ready Paper Submitted</span>
                            <% } else if (Array.isArray(submission.co_authors) && submission.co_authors.includes(user.email)) { %>
                              <span class="badge-submitted">✓ Final Camera Ready Paper Submitted by Primary Author</span>
                            <% } %>
                          <% } else if (submission.submission_status == "Reviewed" ) { %>
                            <span class="badge-reviewed">Awaiting Decision</span>
                          <% } else if (submission.submission_status == "Revision Required" ) { %>
                            <span class="badge-review"><i class="bi bi-info-circle-fill"></i> Revisions Required</span><br>
                            <small>May be reconsidered after revision and re-review</small><br>
                            <% if (submission.primary_author === user.email) { %>
                              <% if (revisedSubmissionsMap && revisedSubmissionsMap[submission.submission_id]) { %>
                                <span class="badge-success mt-2">✓ Revised paper already submitted</span>
                              <% } else { %>
                                <a href="/submission/revised/primary-author/<%= submission.submission_id %>" class="btn btn-sm btn-warning mt-2">
                                  <i class="bi bi-upload"></i> Submit Revised Paper
                                </a>
                              <% } %>
                            <% } else if (Array.isArray(submission.co_authors) && submission.co_authors.includes(user.email)) { %>
                              <small class="text-muted">Only the primary author can submit revised papers.</small>
                            <% } %>
                          <% } else if (submission.submission_status == "Presentation Completed" ) { %>
                            <span class="badge-reviewed">Your presentation is over.</span>

                            <% } else if (submission.submission_status=="Rejected") { %>

                              <span class="badge-reviewed"><a href="/remarks/<%= submission.submission_id%>">View Remarks</a></span>

                            
                          <% } else { %>
                            <span class="badge-rejected"> Not Eligible</span>
                          <% } %>
                        </td>
                        
                        <td>
                          <% 
                              let presentationInfo = null;
                              if (submission.submission_status === "Submitted Final Camera Ready Paper for Oral Presentation") {
                                presentationInfo = trackDetailsMap[submission.track_id];
                              } else if (submission.submission_status === "Submitted Final Camera Ready Paper for Poster Presentation") {
                                presentationInfo = posterSessionsMap[submission.conference_id];
                              }
                          %>
                          <% if (presentationInfo && presentationInfo.presentation_date) { %>
                              <span class="badge-reviewed">Your presentation is on <b><%= presentationInfo.presentation_date %></b> between <b><%= presentationInfo.presentation_start_time %></b> & <b><%= presentationInfo.presentation_end_time %></b></span><br>
                          <% } else if (presentationInfo && presentationInfo.date) { %>
                              <span class="badge-reviewed">Your presentation is on <b><%= presentationInfo.date %></b> between <b><%= presentationInfo.start_time %></b> & <b><%= presentationInfo.end_time %></b></span><br>
                          <% } else if (submission.submission_status === "Presentation Completed") { %>
                              <span class="badge-reviewed">Your presentation is over.</span>
                          <% } else { %> 
                              <span class="badge-rejected">Not Scheduled Yet</span>
                          <% } %>
                        </td>
                        
                        <td style="text-align: center; width: 100px;">
                          <% 
                              const submissionConference = conferences.find(c => c.id == submission.conference_id);
                              let isDeadlinePassed = false;
                              if (submissionConference) {
                                  isDeadlinePassed = currentDate > submissionConference.full_paper_submission;
                              }
                          %>

                          <% if (isDeadlinePassed) { %>
                              <div class="d-flex flex-column align-items-center">
                                <i class="bi bi-lock-fill text-muted"></i>
                                <small class="text-muted">Locked</small>
                              </div>
                          <% } else { %>
                              <% if (submission.primary_author === user.email) { %>
                                  <div class="d-flex flex-column gap-1">
                                    <!-- <a class="btn btn-primary" href="#"><i class="bi bi-person-fill-add"></i></a> -->
                                    <a class="btn btn-sm btn-outline-primary request-btn" href="/submission/view-co-author-requests/<%= submission.submission_id %>"><i class="bi bi-bell-fill"></i></a>
                                    <a class="btn btn-sm btn-outline-warning" href="/submission/edit/primary-author/<%= submission.submission_id %>" role="button" title="Edit Submission">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>
                                    <a class="btn btn-sm btn-outline-danger delete-btn" 
                                       href="/submission/delete/primary-author/<%= submission.submission_id %>" 
                                       data-title="<%= submission.title %>"
                                       role="button"
                                       title="Delete Submission">
                                        <i class="bi bi-trash3-fill"></i>
                                    </a>
                                  </div>
                              <% } else if (Array.isArray(submission.co_authors) && submission.co_authors.includes(user.email)) { %>
                                  <span class="d-inline-block" tabindex="0" data-bs-toggle="popover" data-bs-trigger="hover focus" data-bs-content="Only the primary author can edit or delete the submission.">
                                      <i class="bi bi-lock-fill text-muted"></i>
                                  </span>
                              <% } %>
                          <% } %>
                        </td>
                      </tr>
                      </table>
                    </div>
                  </div>
                </div>

              </div>
            </div>
          </div>
        </div>

        <% }); %> 
      <% } else { %>
        <h6><i class="bi bi-emoji-frown-fill"></i> &nbsp;You have not made any submissions yet.</h6>
      <% } %>
      <hr>

  
    <script src="/script.js"></script>

   
    </div>
   <%- include('partials/footer') %>
  </body>
</html>