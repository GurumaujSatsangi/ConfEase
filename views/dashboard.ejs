<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>DEI CMT</title>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link rel="shortcut icon" href="/dei_logo.png" type="image/x-icon">
    <link rel="stylesheet" href="/styles.css">
  </head>
  <body>
    <%
    // Helper function to format yyyy-mm-dd to dd-mm-yyyy for display
    function formatDateDisplay(dateStr) {
      if (!dateStr) return dateStr;
      const parts = dateStr.split('-');
      if (parts.length === 3) {
        return `${parts[2]}-${parts[1]}-${parts[0]}`;
      }
      return dateStr;
    }
    %>
    <%- include('partials/dashboard/header') %>
    <div class="container">

      <h4>Welcome <%= user.name %> (<%=user.email %>)!</h4>
    
      <hr>

        <h4>Active Conferences</h4>
        <% if (conferences && conferences.length > 0) { %> 

          <table class="table">

            <tr>
              <th>
                TITLE
              </th>
              <th>
                DATES
              </th>
              <th>

              </th>
            </tr>
        
          <% conferences.forEach(function(conference) {  %>
             <tr>
              <td><%= conference.title %></td>
              <td><%= conference.conference_start_date %> - <%= conference.conference_end_date %></td>
              <td><a class="btn btn-primary btn-sm" target="_blank" href="/conference/<%= conference.conference_id %>"><i class="bi bi-arrow-right-circle-fill"></i></a></td>
             </tr>

          
        <% }); %> 
          </table>
      <% } else { %>
        <h6><i class="bi bi-emoji-frown-fill"></i> &nbsp;There are No Active Conferences at the moment.</h6>
      <% } %>

    

  
    <script src="/script.js"></script>

   
    </div>
   <%- include('partials/footer') %>
  </body>
</html>