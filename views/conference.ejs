<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>DEI CMT</title>
    <link rel="stylesheet" href="/styles.css">
</head>
<body>
    <%- include('partials/dashboard/header') %>

    <div class="container">

        <h4><%= conference.title %></h4>

        <% 
          let roleStr = "";
          
          if (user && user.roles) {
            // Check if user.roles is a raw array of database rows
            if (Array.isArray(user.roles)) {
              // Filter roles that match the current conference_id
              const matchedRoles = user.roles.filter(r => r.conference_id === conference.conference_id);
              roleStr = JSON.stringify(matchedRoles).toLowerCase();
            } else {
              // Fallback to object key notation if it is mapped by conference_id
              const myRole = user.roles[conference.conference_id];
              roleStr = myRole ? JSON.stringify(myRole).toLowerCase() : "";
            }
          }
        %>

        <% if(!roleStr){ %>

             <div class="btn-group" role="group">
    <button type="button" class="btn btn-primary btn-sm dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false">
      Create New Submission
    </button>
    <ul class="dropdown-menu">
      <li><a class="dropdown-item" href="/submission/primary-author/<%= conference.conference_id %>">Submit a Paper as Primary Author</a></li>
      <li><a class="dropdown-item" href="/submission/co-author/<%= conference.conference_id %>">Join a Paper as Co-Author</a></li>
    </ul>
     

   </div>
        
   <button type="button" class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#MySubmissions">
  My Submissions
</button>
        
        <% } %>
        
        <% if(roleStr && roleStr.includes('reviewer')) { %>

          
                    <a target="_blank" href="/reviewer/dashboard" class="btn btn-warning btn-sm">
  Review Submissions
                    </a>
             

    

<% } %>

<% if(roleStr && roleStr.includes('invitee')) { %>

    <a href="/submission/invited-talk/<%= conference.conference_id %>" type="button" class="btn btn-primary btn-sm">
  Submit Invited Talk Paper
    </a>

    <button type="button" class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#MySubmissions2">
  My Invited Talk Submissions
</button>

    <% } %>
    
    <% if(roleStr && roleStr.includes('poster_presentation_coordinator')){%>

        <button type="button" class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#MySubmissions">
  Start Poster Presentations
</button>





        <% } %>
        
        <% if(roleStr && roleStr.includes('session_chair')){ %>


        <button type="button" class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#MySubmissions">
  Start Oral Presentation
</button>
        
        <% }%>

          <% if(roleStr && roleStr.includes('meta_reviewer')){ %>


        <a target="_blank" href="/meta-reviewer/dashboard/<%= conference.conference_id %>" class="btn btn-primary btn-sm">
  Meta-Reviewer Dashboard
        </a>
        
        <% }%>

        <button type="button" class="btn btn-primary btn-sm" data-bs-container="body" data-bs-toggle="popover" data-bs-placement="right" data-bs-content="Can't see a specific role you were expecting? Kindly logout and re-login. If the issue still persists, please contact the conference chairs."><i class="bi bi-info-circle-fill"></i>
</button>

<div class="modal fade" id="MySubmissions2" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-xl">
    <div class="modal-content">
      <div class="modal-header">
        <h1 class="modal-title fs-5" id="exampleModalLabel">My Submissions</h1>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">

        <% if(invited_talk_submissions && invited_talk_submissions.length>0) { %>
            <table class="table">
            <tr>
                <th>Submission Title</th>
                <th>View Paper</th>
                <th>Action</th>
            </tr>

            <% invited_talk_submissions.forEach(function(submission){ %>

                <tr>
                    <td><%= submission.title %></td>
                    <td><a class="btn btn-primary btn-sm" target="_blank" href="<%= submission.file_url %>">View</a></td>
                    <td><%= submission.submission_status %></td>
                    <td>
                        
                        <p class="small"><li><a href="/submission/edit/primary-author/<%= submission.submission_id %>">Edit Submission</a>
                    </li><li><a href="/submission/delete/primary-author/<%= submission.submission_id %>">Delete Submission</a></li>
                
            
            </p></td>
                </tr>
            
            <%}) %>

                    </table>

        
        <% } else { %>

            <p class="small">You have not made any submissions.</p>

            <% } %>

        
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
      </div>
    </div>
  </div>
</div>


<div class="modal fade" id="MySubmissions" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-xl">
    <div class="modal-content">
      <div class="modal-header">
        <h1 class="modal-title fs-5" id="exampleModalLabel">My Submissions</h1>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">

        <% if(submissions && submissions.length>0) { %>
            <table class="table">
            <tr>
                <th>Submission Title</th>
                <th>View Paper</th>
                <th>Paper Code</th>
                <th>Co-Authors</th>
                <th>Status</th>
                <th>Action</th>
            </tr>

            <% submissions.forEach(function(submission){ %>

                <tr>
                    <td><%= submission.title %></td>
                    <td><a class="btn btn-primary btn-sm" target="_blank" href="<%= submission.file_url %>">View</a></td>
                    <td><button type="button" class="btn btn-primary btn-sm" data-bs-container="body" data-bs-toggle="popover" data-bs-placement="top" data-bs-content="<%= submission.paper_code %>">View</button></td>
                    <td>
                        <% if(submission.co_authors && submission.co_authors.length>0) { %>

                        <button type="button" class="btn btn-primary btn-sm" data-bs-container="body" data-bs-toggle="popover" data-bs-placement="top" data-bs-content="<%= submission.co_authors %>">View</button></td>

                        
                        <% } else{ %>

                            <p class="small">None</p>

                            <% } %>

                    <td><%= submission.submission_status %></td>
                    <td>
                        
                        <p class="small"><li><a href="/submission/edit/primary-author/<%= submission.submission_id %>">Edit Submission</a>
                    </li><li><a href="/submission/delete/primary-author/<%= submission.submission_id %>">Delete Submission</a></li>
                <li><a target="_blank" href="/submission/view-co-author-requests/<%= submission.submission_id %>">Co-Author Requests</a></li>
            
            </p></td>
                </tr>
            
            <%}) %>

                    </table>

        
        <% } else { %>

            <p class="small">You have not made any submissions.</p>

            <% } %>

        
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
      </div>
    </div>
  </div>
</div>
  
        <hr>

        <h5>Important Dates</h5>
        <p class="small">(All timings are in IST)</p>
        <table class="table">
            
            <tr>
                <th>FULL PAPER SUBMISSION</th>
                <th>ACCEPTANCE NOTIFICATION</th>
                <th>FINAL CAMERA READY PAPER SUBMISSION</th>
                <th>REGISTRATION</th>
            </tr>
            <tr>
                <td><%= conference.full_paper_submission %> (11:59 PM)</td>
                <td><%= conference.acceptance_notification %></td>
                <td><%= conference.camera_ready_paper_submission %> (11:59 PM)</td>
                <td><%= conference.registration %> (11:59 PM)</td>
            </tr>
        </table>

        <h5>Tracks</h5>

        <% if(conference_tracks && conference_tracks.length>0){ %>
            <ul>

            <% conference_tracks.forEach(function(conference_tracks){ %>

                <li><%= conference_tracks.track_name %></li>
            
            <% }) %>
        </ul>
        <% } else { %>

            <p class="small">No Tracks have been added by the Chair! If you think this is an error, please contact the conference Chair.</p>

            <% } %>

    </div>
    
    <%- include('partials/footer') %>

    <script src="/script.js"></script>
</body>
</html>