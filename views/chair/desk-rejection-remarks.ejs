<form action="/submit-desk-rejection-remarks/<%= submission_id %>" method="post">
        <textarea class="form-control" name="remarks"></textarea>
        <button class="btn btn-primary btn-sm" type="submit">Save Remarks & Submit Desk Decision</button>
    </form>

    </div>
    
    <%- include('../partials/footer') %>

    <script src="/script.js"></script>
    
</body>
</html>